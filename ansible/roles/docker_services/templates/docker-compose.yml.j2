services:
  portainer:
    image: portainer/portainer-ce:latest
    container_name: portainer
    restart: always
    ports:
      - "127.0.0.1:9000:9000"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - portainer_data:/data
    networks:
      - homelab_net

  caddy:
    image: caddy:2-alpine
    container_name: caddy
    restart: always
    ports:
      - "127.0.0.1:443:443"
      - "127.0.0.1:443:443/udp"
      - "127.0.0.1:8080:8080"
    volumes:
      - "{{ docker_dir }}/Caddyfile:/etc/caddy/Caddyfile:ro"
      - "{{ docker_dir }}/certs:/etc/caddy/certs:ro"
    networks:
      - homelab_net

  cloudflared:
    image: cloudflare/cloudflared:latest
    container_name: cloudflared
    restart: always
    env_file:
      - "{{ docker_dir }}/.env"
    command: tunnel --no-autoupdate --no-tls-verify run
    networks:
      - homelab_net

  hello:
    image: nginxdemos/hello:latest
    container_name: hello
    restart: always
    networks:
      - homelab_net

volumes:
  portainer_data:

networks:
  homelab_net:
    name: homelab_net
