:80 {
    {% for inst in opencode_instances %}
    handle @inst_{{ inst.name }} host {{ inst.name }}-oc.{{ opencode_public_domain }} {
        reverse_proxy http://opencode-{{ inst.name }}:4096 {
            header_up Host {http.request.host}
            transport http {
                dial_timeout 5s
                response_header_timeout 30s
            }
        }
    }
    {% endfor %}
}
