{
  "name": "Homelab",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",

  // ── Features ──────────────────────────────────────────────────────
  "features": {
    // Docker CLI + Docker Compose (bind-mounts host Docker socket)
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {},
    // PowerShell 7 — needed for Az module and repo scripts
    "ghcr.io/devcontainers/features/powershell:2.0.2": {},
    // Azure CLI — for Bicep validation and ad-hoc queries
    "ghcr.io/devcontainers/features/azure-cli:1": {},
    // GitHub CLI — for PR/issue management, repo operations
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  // ── VS Code customizations ────────────────────────────────────────
  "customizations": {
    "vscode": {
      "settings": {
        "workbench.colorTheme": "Dark Modern",
        "terminal.integrated.defaultProfile.linux": "pwsh",
        "terminal.integrated.profiles.linux": {
          "pwsh": {
            "path": "/usr/bin/pwsh"
          }
        }
      },
      "extensions": [
        "ms-azuretools.vscode-bicep",          // Bicep language support
        "ms-vscode.powershell",                 // PowerShell IDE
        "redhat.ansible",                       // Ansible playbook support
        "bierner.markdown-mermaid",             // Mermaid diagram rendering
        "ms-azuretools.vscode-docker",          // Docker Explorer
        "github.vscode-pull-request-github",    // PR/issue integration
        "github.copilot",                       // GitHub Copilot code completions
        "github.copilot-chat",                  // GitHub Copilot Chat
        "vizards.deepseek-v4-for-copilot",      // DeepSeek V4 model picker for Copilot Chat
        "ms-azuretools.vscode-azure-mcp-server" // Azure MCP Server (resource mgmt, queries)
      ]
    }
  },

  // ── Post-create scripts ──────────────────────────────────────────
  // Fast steps (Ansible, Bicep) run synchronously.
  // Az PowerShell is backgrounded — huge module, can take minutes.
  // Check Az progress: tail -f /tmp/install-az.log
  "postCreateCommand": "bash .devcontainer/scripts/setup-ansible.sh && bash .devcontainer/scripts/setup-bicep.sh && pwsh -File .devcontainer/scripts/setup-profile.ps1 && nohup pwsh -File .devcontainer/scripts/setup-azps.ps1 > /tmp/install-az.log 2>&1 &",

  // ── Remote user ───────────────────────────────────────────────────
  "remoteUser": "vscode"
}
